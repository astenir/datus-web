{
  "name": "datus-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0",
    "lint:typography": "node scripts/lint-typography.mjs",
    "api:pull": "node scripts/sync-openapi.mjs",
    "api:types": "openapi-typescript openapi.json -o src/types/openapi.ts && node scripts/strip-openapi-comments.mjs",
    "api:sync": "npm run api:pull && npm run api:types",
    "api:smoke": "node scripts/smoke-api.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@rive-app/webgl2": "^2.38.2",
    "@tanstack/vue-table": "^8.21.3",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/node-toolbar": "^1.1.1",
    "@vueuse/core": "^14.3.0",
    "ai": "^6.0.208",
    "ansi-to-vue3": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "markdown-it": "^14.2.0",
    "media-chrome": "^4.19.2",
    "motion-v": "^2.3.0",
    "nanoid": "^5.1.15",
    "reka-ui": "^2.10.0",
    "shadcn-vue": "^2.7.4",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "vue-stick-to-bottom": "^1.0.0",
    "vue-stream-markdown": "^1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
